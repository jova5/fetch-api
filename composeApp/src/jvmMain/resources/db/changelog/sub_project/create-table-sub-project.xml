<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet author="mjovicic" id="1775835010000-1">
    <createTable tableName="sub_project">
      <column name="id" type="INTEGER" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="project_id" type="INTEGER">
        <constraints
          nullable="false"
          foreignKeyName="fk_sub_project_project"
          references="project(id)"/>
      </column>
      <column name="name" type="VARCHAR(50)">
        <constraints nullable="false"/>
      </column>
      <!-- auth_type: NONE | API_KEY | BEARER | BASIC | OAUTH2 -->
      <column name="auth_type" type="VARCHAR(50)" defaultValue="NONE">
        <constraints nullable="false"/>
      </column>
      <!-- auth_config stores auth details as JSON e.g. {"token": "abc"} -->
      <column name="auth_config" type="TEXT"/>
    </createTable>
  </changeSet>

</databaseChangeLog>
