<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet author="mjovicic" id="1775835845000-1">
    <createTable tableName="request">
      <column name="id" type="INTEGER" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="sub_project_id" type="INTEGER">
        <constraints
          nullable="false"
          foreignKeyName="fk_request_sub_project"
          references="sub_project(id)"/>
      </column>
      <!-- nullable: request can be directly in sub_project or inside a folder -->
      <column name="folder_id" type="INTEGER">
        <constraints
          nullable="true"
          foreignKeyName="fk_request_folder"
          references="folder(id)"/>
      </column>
      <column name="name" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <!-- method: GET | POST | PUT | PATCH | DELETE | HEAD | OPTIONS -->
      <column name="method" type="VARCHAR(10)">
        <constraints nullable="false"/>
      </column>
      <column name="url" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <!-- headers, body stored as JSON -->
      <column name="headers" type="TEXT"/>
      <column name="body" type="TEXT"/>
    </createTable>
  </changeSet>

</databaseChangeLog>
